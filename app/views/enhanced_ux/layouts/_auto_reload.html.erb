<!--
// Path pattern:
// Insertion position: Head of all pages
// Type:               HTML
// Comment:            Auto reload
-->
<script>
  $(() => {
    const resourcesAll = {
      en: {
        autoReload: "Auto reload",
        errorLoading: "Failed to reload the content.",
        seconds: "seconds",
        minutes: "minutes",
        description: "Automatically reload the page at the specified interval.",
        labelActive: "Auto-reload is active",
        messageFailedToSetInterval:
          "Failed to set auto-reload interval. " +
          "Please specify between %0 minutes and %1 minutes.",
        labelAutoReloadSettings: "Auto-reload Settings",
        labelSettings: "Settings",
        labelResetAndReload: "Reset and Reload",
        messageConfirmResetSettings:
          "Are you sure you want to reset the settings to their default values?",
        labelSaveAndReload: "Save and Reload",
        labelCancel: "Cancel",
        errorDescription:
          "Failed to save settings due to the following error(s).",
        labelAvailableAutoReloadIntervals:
          "Available auto-reload intervals (minutes)",
        labelDefaultAutoReloadInterval:
          "Default auto-reload interval (minutes)",
        labelRestorePreviousAutoReloadState:
          "Restore previous auto-reload state from local storage automatically",
        labelControllerActionsToShowAutoReloadMenu:
          "Controller and Actions to show auto-reload menu",
        labelController: "Controller",
        labelActions: "Actions",
        labelRemove: "Remove",
        labelAddControllerActions: "Add Controller and Actions",
      },
      ja: {
        autoReload: "自動更新",
        errorLoading: "コンテンツの読み込みに失敗しました。",
        seconds: "秒間隔",
        minutes: "分間隔",
        description: "ページを指定の間隔で自動更新します。",
        labelActive: "自動更新が有効です",
        messageFailedToSetInterval:
          "自動更新の間隔の設定に失敗しました。" +
          "最小 %0 分、最大 %1 分の範囲で指定してください。",
        labelAutoReloadSettings: "自動更新設定",
        labelSettings: "設定",
        labelResetAndReload: "リセットして再読み込み",
        messageConfirmResetSettings: "設定を初期状態に戻してもよろしいですか？",
        labelSaveAndReload: "保存して再読み込み",
        labelCancel: "キャンセル",
        errorDescription: "以下のエラーのため、設定を保存できませんでした。",
        labelAvailableAutoReloadIntervals: "利用可能な自動更新間隔（分）",
        labelDefaultAutoReloadInterval: "デフォルトの自動更新間隔（分）",
        labelRestorePreviousAutoReloadState:
          "前回の自動更新状態をローカルストレージから自動で復元",
        labelControllerActionsToShowAutoReloadMenu:
          "自動更新メニューを表示するコントローラーとアクション",
        labelController: "コントローラー",
        labelActions: "アクション",
        labelRemove: "削除",
        labelAddControllerActions: "コントローラーとアクションを追加",
      },
    };
    const resources =
      resourcesAll[document.documentElement.lang] || resourcesAll["en"];

    const homeUrl = ($("[src*='/jquery-'][src*='-ui-'][src*='.js']").attr("src")
      ?.match(/^(.*?)(?:\/javascripts\/|\/assets\/)/)
      ?.[1] || "") + "/";
    const localStorageKeyPrefix = homeUrl.slice(1).replaceAll("/", ".");
    
    const settingsDefault = {
      availableIntervalMins: [0.25, 0.5, 1, 3, 5, 10, 15, 30, 60],
      defaultIntervalMin: 1,
      lastUsedIntervalMin: null,
      restoreFromLocalStorage: false,
      availableControllerAndActions: [
        { controller: "activities", actions: ["index"] },
        { controller: "issues", actions: ["index", "gantt"] },
        { controller: "versions", actions: ["index", "show"] },
        { controller: "timelog", actions: ["index"] },
        { controller: "calendars", actions: ["show"] },
        { controller: "news", actions: ["index"] },
        { controller: "issue_note_list", actions: ["index"] },
      ],
    };

    const settings = {
      ...settingsDefault,
      ...JSON.parse(
        localStorage.getItem(localStorageKeyPrefix + "autoReloadSettings") ||
          "{}",
      ),
    };

    const controller = [...document.body.classList]
      .filter((i) => i.startsWith("controller"))[0]
      .split("-")[1];
    const action = [...document.body.classList]
      .filter((i) => i.startsWith("action"))[0]
      .split("-")[1];
    if (
      !settings.availableControllerAndActions.some(
        (item) =>
          item.controller === controller && item.actions.includes(action),
      )
    ) {
      return;
    }

    const minimalIntervalMin = Math.min(...settings.availableIntervalMins);
    const maximalIntervalMin = Math.max(...settings.availableIntervalMins);

    const svgIcons = new (class SVGIcons {
      constructor() {
        const extractedPath = this.#extractIconPath();
        this.basePath = extractedPath ? homeUrl + extractedPath : null;
      }
      #extractIconPath() {
        const $elem = $("use[href*='/assets/icons-'][href*='.svg#']").first();
        const match = $elem
          .attr("href")
          ?.match(/\/(assets\/icons-[a-f0-9]+\.svg)#/);
        return match ? match[1] : null;
      }
      generateSvgIconTag(key) {
        if (!this.basePath) return null;
        return $(
          `<svg class="s18 icon-svg" aria-hidden="true">` +
            `<use href="${this.basePath}#${key}"></use>` +
            `</svg>`,
        );
      }
      get settings() {
        return this.generateSvgIconTag("icon--settings");
      }
      get del() {
        return this.generateSvgIconTag("icon--del");
      }
    })();

    // Determine whether to enable auto-reload based on URL parameters
    const urlParams = new URLSearchParams(window.location.search);
    const hasAutoReloadParam = urlParams.has("auto_reload");

    let timerId = null;
    let isPageVisible = !document.hidden;
    let intervalMin = null; // Store the interval for resuming

    function saveSettings() {
      localStorage.setItem(
        localStorageKeyPrefix + "autoReloadSettings",
        JSON.stringify(settings),
      );
    }

    // Page Visibility API: Handle background/foreground state
    document.addEventListener("visibilitychange", () => {
      isPageVisible = !document.hidden;

      if (isPageVisible && intervalMin && intervalMin > 0) {
        // Resume auto-reload when page becomes visible
        clearInterval(timerId);
        timerId = setInterval(reload, intervalMin * 1000 * 60);
        reload(); // Immediate reload
        console.log(`[${new Date().toLocaleString()}] Auto-reload resumed.`);
      } else if (!isPageVisible && timerId) {
        // Pause auto-reload when page goes to background
        clearInterval(timerId);
        timerId = null;
        console.log(`[${new Date().toLocaleString()}] Auto-reload paused.`);
      }
    });

    function intervalsStringToArray(str) {
      return str
        .split(",")
        .map((i) => parseFloat(i.trim()))
        .filter(
          (i) =>
            !isNaN(i) && i >= minimalIntervalMin && i <= maximalIntervalMin,
        );
    }

    const $settingsPanel = $("<div>").attr(
      "id",
      "auto-reload-settings-panel-content",
    );
    function openAutoReloadSettingsDialog() {
      $settingsPanel.empty();
      $settingsPanel.attr("title", resources.labelAutoReloadSettings).dialog({
        modal: true,
        width: 500,
        buttons: {
          [resources.labelResetAndReload]: function () {
            if (confirm(resources.messageConfirmResetSettings)) {
              Object.assign(settings, settingsDefault);
              saveSettings();
              location.reload();
            }
          },
          [resources.labelSaveAndReload]: function () {
            try {
              settings.availableIntervalMins = intervalsStringToArray(
                $intervalsInput.val(),
              );
              settings.restoreFromLocalStorage =
                $restoreStateCheckbox.is(":checked");
              settings.defaultIntervalMin = parseFloat(
                $defaultIntervalSelect.val(),
              );
              settings.availableControllerAndActions =
                serializeControllerAndActions();
              saveSettings();
              location.reload();
            } catch (e) {
              alert(resources.errorDescription + "\n" + e.message);
              return;
            }
          },
          [resources.labelCancel]: function () {
            $(this).dialog("close");
          },
        },
      });

      // Available intervals
      const $intervalsBox = $("<div>");
      const $intervalsLabel = $("<label>")
        .attr({ for: "auto_reload_intervals_setting" })
        .text(resources.labelAvailableAutoReloadIntervals + ":")
        .appendTo($intervalsBox);
      const $intervalsInput = $(`<input>`)
        .attr({
          type: "text",
          id: "auto_reload_intervals_setting",
        })
        .css({ width: "100%" })
        .val(settings.availableIntervalMins.join(", "))
        .appendTo($intervalsBox);
      $settingsPanel.append($intervalsBox);

      // Default interval
      const $defaultIntervalBox = $("<div>");
      const $defaultIntervalLabel = $("<label>")
        .attr({ for: "auto_reload_default_interval_setting" })
        .text(resources.labelDefaultAutoReloadInterval + ":")
        .appendTo($defaultIntervalBox);
      const $defaultIntervalSelect = $(`<select>`)
        .attr("id", "auto_reload_default_interval_setting")
        .css("width", "100%")
        .appendTo($defaultIntervalBox);
      settings.availableIntervalMins.forEach((min) =>
        $("<option>")
          .attr("value", min)
          .prop("selected", min === settings.defaultIntervalMin)
          .text(
            min < 1
              ? min * 60 + " " + resources.seconds
              : min + " " + resources.minutes,
          )
          .appendTo($defaultIntervalSelect),
      );
      $settingsPanel.append($defaultIntervalBox);

      // Restore previous state checkbox
      const $restoreStateBox = $("<div>");
      const $restoreStateCheckbox = $(`<input>`)
        .attr({
          type: "checkbox",
          id: "auto_reload_restore_state_setting",
        })
        .prop("checked", settings.restoreFromLocalStorage)
        .appendTo($restoreStateBox);
      const $restoreStateLabel = $(`<label>`)
        .attr({ for: "auto_reload_restore_state_setting" })
        .text(resources.labelRestorePreviousAutoReloadState)
        .appendTo($restoreStateBox);
      $settingsPanel.append($restoreStateBox);

      // Controller/Action selector
      const $controllerActionSelector = generateControllerAndActionSelector();
      $settingsPanel.append($controllerActionSelector);
    }

    function generateControllerAndActionSelector() {
      const $controllerAndActionSelector = $("<fieldset>").attr(
        "id",
        "auto_reload_controller_action_setting",
      );

      // Title
      $controllerAndActionSelector.append(
        $("<legend>")
          .addClass("auto_reload_controller_action_setting_title")
          .text(resources.labelControllerActionsToShowAutoReloadMenu),
      );

      // Header
      const $controllerAndActionSelectorGrid = $("<div>")
        .attr("id", "auto_reload_controller_action_setting_grid")
        .appendTo($controllerAndActionSelector);
      $controllerAndActionSelectorGrid.append(
        $("<div>")
          .attr({ id: "auto_reload_controller_action_setting_labels" })
          .append(
            $("<span>")
              .addClass("auto_reload_controller_label")
              .append($("<strong>").text(resources.labelController)),
          )
          .append(
            $("<span>")
              .addClass("auto_reload_actions_label")
              .append($("<strong>").text(resources.labelActions)),
          )
          .append(
            $("<span>")
              .addClass("auto_reload_remove_label")
              .append($("<strong>").text(resources.labelRemove)),
          ),
      );

      // Existing items
      function generateItem(controller, actions) {
        const id = Math.random().toString(36).substring(2, 10);
        const $item = $("<div>");
        const $controllerInput = $(`<input>`)
          .attr({ type: "text", id: `auto_reload_controller_${id}` })
          .val(controller)
          .addClass("auto_reload_controller_input");
        const $actionsInput = $(`<input>`)
          .attr({ type: "text", id: `auto_reload_actions_${id}` })
          .val(actions.join(", "))
          .addClass("auto_reload_actions_input");
        const $removeButton = $("<a>")
          .addClass("icon icon-del icon-only remove_controller_action")
          .on("click", () => {
            $item.remove();
          });
        if (svgIcons.del) {
          $removeButton.append(svgIcons.del);
        }
        return $item.append($controllerInput, $actionsInput, $removeButton);
      }
      settings.availableControllerAndActions.forEach((item) => {
        const $item = generateItem(item.controller, item.actions);
        $controllerAndActionSelectorGrid.append($item);
      });

      // Add button
      const $addButton = $("<button>")
        .attr({ type: "button" })
        .text(resources.labelAddControllerActions)
        .addClass("icon icon-add add_controller_action")
        .on("click", () => {
          const $item = generateItem("", []);
          $controllerAndActionSelectorGrid.append($item);
        });
      $controllerAndActionSelector.append($addButton);

      return $controllerAndActionSelector;
    }

    function serializeControllerAndActions() {
      const newSettings = [];
      $("#auto_reload_controller_action_setting_grid > div").each((i, e) => {
        const $item = $(e);
        if ($item.is("#auto_reload_controller_action_setting_labels")) return;
        const controller = $item
          .find("input.auto_reload_controller_input")
          .val()
          ?.trim();
        const actions = $item
          .find("input.auto_reload_actions_input")
          .val()
          ?.split(",")
          .map((a) => a.trim())
          .filter((a) => a.length > 0);
        if (controller && actions.length > 0) {
          newSettings.push({ controller: controller, actions: actions });
        }
      });
      return newSettings;
    }

    async function reload() {
      try {
        if (window.ajaxUpdateIssueList) {
          await window.ajaxUpdateIssueList();
        } else {
          location.reload();
          return;
          // TODO: Fetch the contents.
          // Note: Conflicts with the other features and plugins.
        }
        appendCheckbox(); // Restore the check box
        console.log(`[${new Date().toLocaleString()}] Reloaded.`);
      } catch (error) {
        console.error(error);
        showError(resources.errorLoading);
        enableAutoReload(null);
      }
    }

    function showError(message) {
      const $message = $("#auto_reload_message");
      $message.text(message).show().attr("class", "").addClass("error");
      $checkboxControl.css("opacity", 1);

      setTimeout(() => {
        $message.fadeOut(300, () => {
          $checkboxControl.css("opacity", "");
        });
      }, 10000);
    }

    function selectIntervalItem(intervalMin) {
      $menu.find("li").each((i, e) => {
        const $e = $(e);
        if (parseFloat($e.data("minutes")) === intervalMin) {
          $e.addClass("selected");
        } else {
          $e.removeClass("selected");
        }
      });
    }

    // Generate a toggle switch to enable/disable
    const $checkbox = $('<input type="checkbox">').attr({
      id: "enable_auto_reload",
    });
    const $message = $("<span>").attr("id", "auto_reload_message");

    // Interval selection menu
    const $menu = $("<ul>").attr({ id: "auto_reload_menu", title: "" });
    settings.availableIntervalMins.forEach((i) => {
      const label = i < 1 ? resources.seconds : resources.minutes;
      const $item = $(
        `<li><div>${i < 1 ? i * 60 : i} ${label}</div></li>`,
      ).data("minutes", i);
      $menu.append($item);
    });

    // Append settings menu link
    const $settingsAnchor = $("<a>")
      .addClass("icon icon-settings")
      .text(resources.labelSettings);
    if (svgIcons.settings) {
      $settingsAnchor.prepend(svgIcons.settings);
    }
    $menu.append(
      $("<li>")
        .addClass("settings-link")
        .append($("<div>").append($settingsAnchor))
        .on("click", openAutoReloadSettingsDialog),
    );

    const $checkboxControl = $("<span>")
      .attr({ title: resources.description, id: "auto_reload_controller" })
      .append($checkbox)
      .append(
        $("<label>")
          .attr({ for: "enable_auto_reload", "data-i18n": "autoReload" })
          .html(resources.autoReload),
      )
      .append($message)
      .append($menu);

    function updateUrl(intervalMin) {
      const url = new URL(window.location);
      if (intervalMin) {
        url.searchParams.set("auto_reload", intervalMin);
      } else {
        url.searchParams.delete("auto_reload");
      }
      window.history.replaceState({}, "", url);
    }

    function enableAutoReload(newIntervalMin = null) {
      clearInterval(timerId);
      timerId = null;

      const state = newIntervalMin && newIntervalMin > 0;

      if (state) {
        selectIntervalItem(newIntervalMin);
        // Only start the timer if the page is visible
        if (isPageVisible) {
          timerId = setInterval(reload, newIntervalMin * 1000 * 60);
        }
        intervalMin = newIntervalMin; // Store for resuming later
        $checkboxControl.attr(
          "title",
          `${resources.labelActive} (${
            newIntervalMin < 1
              ? newIntervalMin * 60 + " " + resources.seconds
              : newIntervalMin + " " + resources.minutes
          })`,
        );
      } else {
        newIntervalMin = 0;
        intervalMin = 0;
        selectIntervalItem(0);
        $checkboxControl.attr("title", resources.description);
      }

      $checkbox.prop("checked", state);

      settings.lastUsedIntervalMin = newIntervalMin;
      saveSettings();

      updateUrl(newIntervalMin);
    }

    function appendCheckbox() {
      if ($("#auto_reload_controller").length > 0) return;

      // Note: The insertion position is different depending on the page.
      if ($("#content > .other-formats").length > 0) {
        $("#content > .other-formats:first").append($checkboxControl);
      } else {
        if ($(".enable_2-pane_mode_box").length > 0) {
          $(".enable_2-pane_mode_box").after($checkboxControl);
        } else {
          if (/\/versions\/[0-9]+$/.test(location.pathname)) {
            $("#roadmap>h2+span.badge:first").after($checkboxControl);
          } else {
            $("#content>h2").append($checkboxControl);
          }
        }
      }
      $checkbox.on("change", function () {
        enableAutoReload(
          $(this).is(":checked") ? settings.defaultIntervalMin : null,
        );
      });
      setupMenu();
    }

    function setupMenu() {
      $checkboxControl.hover(
        () => {
          let positionSettings = {
            my: "left top",
            at: "left bottom",
            of: $checkboxControl.find("label"),
          };
          if (
            $(auto_reload_controller).closest($(".other-formats")).length > 0
          ) {
            positionSettings["my"] = "right bottom";
            positionSettings["at"] = "right top";
          }
          $menu.show().position(positionSettings);
        },
        () => {
          setTimeout(() => {
            $menu.hide();
          });
        },
      );

      $menu
        .menu({
          select: function (event, ui) {
            setTimeout(() => {
              $menu.hide();
            });
            if (ui.item.hasClass("settings-link")) return;
            enableAutoReload(parseFloat(ui.item.data("minutes")));
          },
        })
        .hide();
    }

    // Initialize
    appendCheckbox();

    function validateInterval(
      intervalMin,
      minimalIntervalMin = minimalIntervalMin,
      maximalIntervalMin = maximalIntervalMin,
    ) {
      const parsedIntervalMin = parseFloat(intervalMin);
      if (
        !parsedIntervalMin ||
        parsedIntervalMin < minimalIntervalMin ||
        parsedIntervalMin > maximalIntervalMin
      ) {
        console.warn(
          `Invalid auto-reload interval: ${intervalMin}. ` +
            `Must be between ${minimalIntervalMin} and ${maximalIntervalMin}.`,
        );
        return null;
      }
      return parsedIntervalMin;
    }

    if (hasAutoReloadParam || settings.restoreFromLocalStorage) {
      const resolvedIntervalMin = hasAutoReloadParam
        ? validateInterval(
            urlParams.get("auto_reload"),
            minimalIntervalMin,
            maximalIntervalMin,
          )
        : settings.restoreFromLocalStorage
          ? validateInterval(
              settings.lastUsedIntervalMin,
              minimalIntervalMin,
              maximalIntervalMin,
            )
          : null;

      if (resolvedIntervalMin) {
        enableAutoReload(parseFloat(resolvedIntervalMin));
      } else {
        enableAutoReload(null);
        alert(
          resources.messageFailedToSetInterval
            .replace("%0", minimalIntervalMin)
            .replace("%1", maximalIntervalMin),
        );
      }
    }
  });
</script>
<style>
  #auto_reload_controller {
    display: inline-flex;
    align-items: center;
    opacity: 0.3;
    &:hover {
      opacity: 1;
    }

    #enable_auto_reload {
      margin-left: 10px;
      margin-right: 5px;
      cursor: pointer;
      height: 13px;
      & + label {
        font-size: 12px;
        font-weight: normal;
        cursor: pointer;
      }
    }
    #auto_reload_message {
      display: none;
      margin: 1px 5px;
      padding: 1px 5px;
      border-radius: 3px;
      font-size: 11px;
      &.error {
        color: red;
        outline: 1px red solid;
        background-color: #fdd;
      }
    }
    #auto_reload_menu {
      display: none;
      position: absolute;
      background-color: #fff;
      border: 1px solid #ccc;
      border-radius: 3px;
      padding: 5px;
      box-shadow: 0 0 5px rgba(0, 0, 0, 0.5);
      z-index: 1000;
      font-size: 12px;
      font-weight: normal;
      li {
        cursor: pointer;
        &.selected {
          background-color: #ddd;
        }

        &.settings-link {
          border-top: 1px solid #ccc;
          margin-top: 5px;
          padding-top: 5px;
          > div {
            text-align: center;
            a:not(:has(svg)) {
              text-decoration: none;
              color: inherit;
              padding: 4px 8px 4px 20px;
            }
          }
        }
      }
    }
  }

  .ui-dialog:has(#auto-reload-settings-panel-content) {
    .ui-dialog-buttonset button {
      height: auto;
    }

    #auto-reload-settings-panel-content {
      padding: 10px;

      > div,
      > fieldset {
        margin-bottom: 15px;
      }

      #auto_reload_controller_action_setting {
        align-items: center;
        .auto_reload_controller_action_setting_title {
          margin-bottom: 5px;
        }

        #auto_reload_controller_action_setting_grid {
          display: grid;
          grid-template-columns: 1fr 1fr auto;
          gap: 3px 3px;

          #auto_reload_controller_action_setting_labels {
            display: contents;
          }

          > div:not(#auto_reload_controller_action_setting_labels) {
            display: contents;

            .auto_reload_controller_input,
            .auto_reload_actions_input {
              width: 100%;
            }

            .remove_controller_action {
              justify-self: center;
              align-self: center;
              cursor: pointer;
            }
          }
        }

        .add_controller_action {
          float: right;
          margin-right: 10px;
          margin-top: 10px;
          cursor: pointer;
        }
      }
    }
  }
</style>
